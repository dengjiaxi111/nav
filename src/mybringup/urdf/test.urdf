<?xml version="1.0" ?>

<robot name="sentry" >
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <link name="base_footprint">
    <visual>
      <geometry>
        <sphere radius="0.001"/>
      </geometry>
    </visual>
  </link>
 
  <!--chassis -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.48 0.48 0.1"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="yellow">
        <color rgba="0.8 0.3 0.1 0.5"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.48 0.48 0.2"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="13"/>
      <inertia ixx="0.26043333333333335" ixy="0" ixz="0" iyy="0.49920000000000003" iyz="0" izz="0.26043333333333335"/>
    </inertial>
  </link>
  <joint name="base_link2base_footprint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1"/>
  </joint>
  <gazebo reference="base_link">
    <material>Gazebo/Yellow</material>
  </gazebo>
  <!-- WHEELS -->
  <link name="FL_Steer">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.035"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.02" radius="0.035"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0001697916666666667" ixy="0" ixz="0" iyy="0.0001697916666666667" iyz="0" izz="0.00030625000000000004"/>
    </inertial>
  </link>
  <joint name="FL_Steer2base_link" type="continuous">
    <parent link="base_link"/>
    <child link="FL_Steer"/>
    <origin xyz="0.2 0.2 -0.055"/>
    <axis xyz="0 0 1"/>
  </joint>
  <gazebo reference="FL_Steer">
    <material>Gazebo/Red</material>
  </gazebo>
  <link name="FL_Susp">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.035"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.02" radius="0.035"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0001697916666666667" ixy="0" ixz="0" iyy="0.0001697916666666667" iyz="0" izz="0.00030625000000000004"/>
    </inertial>
  </link>
  <joint name="FL_Susp2FL_Steer" type="prismatic">
    <parent link="FL_Steer"/>
    <child link="FL_Susp"/>
    <limit effort="1000" lower="-0.02" upper="0.02" velocity="1000"/>
    <origin xyz="0 0 -0.05"/>
    <axis xyz="0 0 1"/>
  </joint>
  <gazebo reference="FL_Susp2FL_Steer">
    <implicitSpringDamper>true</implicitSpringDamper>
    <springStiffness>4000</springStiffness>
    <springReference>0</springReference>
  </gazebo>
  <gazebo reference="FL_Susp">
    <material>Gazebo/Red</material>
  </gazebo>
  <link name="FL_wheel">
    <visual>
      <geometry>
        <cylinder length="0.015" radius="0.035"/>
      </geometry>
      <origin rpy="1.5705 0 0" xyz="0 0 0"/>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.015" radius="0.035"/>
      </geometry>
      <origin rpy="1.5705 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.00032500000000000004" ixy="0" ixz="0" iyy="0.00032500000000000004" iyz="0" izz="0.0006125000000000001"/>
    </inertial>
  </link>
  <joint name="FL_wheel2FL_Susp" type="continuous">
    <parent link="FL_Susp"/>
    <child link="FL_wheel"/>
    <origin xyz="0 0 -0.045"/>
    <axis xyz="0 1 0"/>
  </joint>
  <gazebo reference="FL_wheel">
    <material>Gazebo/Black</material>
    <mu1>0.7</mu1>
    <mu2>0.7</mu2>
  </gazebo>

