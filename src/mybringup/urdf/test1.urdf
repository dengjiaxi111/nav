  <gazebo reference="livox">
    <sensor name="livox" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <!-- This ray plgin is only for visualization. -->
      <plugin filename="libros2_livox.so" name="livox_plugin">
        <ray>
          <scan>
            <horizontal>
              <samples>100</samples>
              <resolution>1</resolution>
              <min_angle>0</min_angle>
              <max_angle>6.2831852</max_angle>
            </horizontal>
            <vertical>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-0.12601276984444446</min_angle>
              <max_angle>0.9637707965111111</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.1</min>
            <max>80.0</max>
            <resolution>0.05</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
        <visualize>false</visualize>
        <samples>10000</samples>
        <downsample>1</downsample>
        <csv_file_name>/home/lehan/lio_3se_ros2/install/ros2_livox_simulation/share/ros2_livox_simulation/scan_mode/mid360.csv</csv_file_name>
        <topic>/livox/lidar</topic>
      </plugin>
    </sensor>
  </gazebo>
